# Database Config
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spacetrack"

# Space-Track Credentials
SPACE_TRACK_USERNAME=your_email@example.com
SPACE_TRACK_PASSWORD=your_password

# AI Provider Keys (add the ones you have — at least one required)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=AI...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

# AI Configuration
AI_PROVIDER_PRIORITY=anthropic,openai,google,groq,openrouter
